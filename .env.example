# ================================
# RAÍZES DO NORDESTE API - ENV
# ================================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/raizes_nordeste?schema=public"

# JWT
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_min_32_chars
JWT_EXPIRES_IN=24h

# Payment Mock (serviço externo simulado)
PAYMENT_GATEWAY_URL=https://mock-payment.raizesnordeste.com
PAYMENT_GATEWAY_TOKEN=mock_token_123

# Logs
LOG_LEVEL=info
